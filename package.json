{
  "name": "judgekit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "lint:bash": "bash -n deploy-docker.sh && bash -n deploy.sh",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:watch": "vitest",
    "test:security": "vitest run tests/unit/security",
    "db:push": "JUDGEKIT_HOST_DATABASE_URL=1 drizzle-kit push",
    "db:push:dev": "JUDGEKIT_HOST_DATABASE_URL=1 drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:check": "bash scripts/check-migration-drift.sh",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "backup:db": "bash scripts/backup-db.sh",
    "backup:verify": "bash scripts/verify-db-backup.sh",
    "db:studio": "JUDGEKIT_HOST_DATABASE_URL=1 drizzle-kit studio",
    "seed": "JUDGEKIT_HOST_DATABASE_URL=1 tsx scripts/seed.ts",
    "languages:sync": "JUDGEKIT_HOST_DATABASE_URL=1 tsx scripts/sync-language-configs.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:component": "vitest run --config vitest.config.component.ts",
    "test:harness": "vitest run --config vitest.config.harness.ts",
    "test:e2e": "JUDGEKIT_HOST_DATABASE_URL=1 playwright test"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@base-ui/react": "^1.4.1",
    "@codemirror/commands": "^6.10.2",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@lezer/highlight": "^1.2.3",
    "@tailwindcss/typography": "^0.5.19",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "highlight.js": "^11.11.1",
    "isomorphic-dompurify": "^3.10.0",
    "jszip": "^3.10.1",
    "jose": "^6.2.0",
    "katex": "^0.16.38",
    "lru-cache": "^11.2.7",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.14",
    "next": "^16.2.9",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.1",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pretendard": "^1.3.9",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shadcn": "^4.4.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "thememirror": "^2.0.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "hono": "^4.12.14",
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25",
    "@types/nodemailer": "^7.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.5"
  }
}
