# =============================================================================
# JudgeKit Production Environment
# Copy to .env.production and fill in required values.
# =============================================================================

# Auth (REQUIRED — generate with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=https://oj-internal.maum.ai
# Trust client-supplied X-Forwarded-Host. Defaults to false so the app relies on
# the reverse-proxy-provided Host header instead. Set to true only if the proxy
# does not set X-Forwarded-Host and auth callbacks fail with UntrustedHost.
# In production, AUTH_TRUST_HOST=true requires TRUST_HOST_OVERRIDE=1 below.
AUTH_TRUST_HOST=false
# Optional OpenID Connect provider for trusted first-party applications.
# Set all values before changing OIDC_ENABLED to 1.
OIDC_ENABLED=0
# OIDC_ISSUER=https://oj.auraedu.me
# OIDC_CLIENT_ID=info-course-portal
# OIDC_CLIENT_SECRET=
# OIDC_CLIENT_REDIRECT_URIS=["https://info.auraedu.me/api/auth/callback/judgekit"]
# OIDC_SIGNING_PRIVATE_KEY_B64=
# OIDC_SIGNING_KEY_ID=judgekit-2026-01
# Break-glass override for AUTH_TRUST_HOST in production. Set to 1 only after
# confirming the reverse proxy strips untrusted X-Forwarded-Host values before
# they reach the app. Leave unset in normal operation.
# TRUST_HOST_OVERRIDE=0

# Database (PostgreSQL runtime only)
DB_DIALECT=postgresql
DATABASE_URL=postgres://judgekit:judgekit@db:5432/judgekit

# Optional: when set to 1, deploy-docker.sh passes --force to drizzle-kit push,
# auto-applying destructive schema changes (e.g., DROP COLUMN). Only use after
# reviewing the diff in the deploy log. The Step 5b psql backfill in
# deploy-docker.sh runs regardless of this flag — see AGENTS.md "Database
# migration recovery (DRIZZLE_PUSH_FORCE)" section.
# DRIZZLE_PUSH_FORCE=0

# Required for plugin secret storage and API key encryption
PLUGIN_CONFIG_ENCRYPTION_KEY=

# REQUIRED (startup gate refuses to boot without it): AES-256-GCM key for
# secrets stored in the DB (SMTP password, hCaptcha secret, API keys).
# A DIFFERENT key from PLUGIN_CONFIG_ENCRYPTION_KEY — generate each
# independently with: openssl rand -hex 32
NODE_ENCRYPTION_KEY=

# Optional: prior key(s) for zero-downtime rotation (NEW-B). Comma-separated
# list of 64-char hex strings. Leave unset for normal operation. To rotate:
#   1. set NODE_ENCRYPTION_KEY_PREVIOUS=<old key>
#   2. set NODE_ENCRYPTION_KEY=<new key>
#   3. deploy — old ciphertexts decrypt via PREVIOUS, new writes use the new key
# Remove PREVIOUS once all columns are re-encrypted (lazy on next write).
NODE_ENCRYPTION_KEY_PREVIOUS=

# Judge Worker (REQUIRED — generate with: openssl rand -hex 32)
JUDGE_AUTH_TOKEN=

# Realtime/SSE coordination
# Supported modes:
#   - process-local mode: declare APP_INSTANCE_COUNT=1 (or REALTIME_SINGLE_INSTANCE_ACK=1)
#   - shared PostgreSQL mode: set REALTIME_COORDINATION_BACKEND=postgresql
APP_INSTANCE_COUNT=1
# REALTIME_SINGLE_INSTANCE_ACK=1
# REALTIME_COORDINATION_BACKEND=postgresql

# Judge Worker tuning
JUDGE_CONCURRENCY=2
POLL_INTERVAL=500
JUDGE_DISABLE_CUSTOM_SECCOMP=0
JUDGE_ALLOW_DEFAULT_COMPILE_SECCOMP=0
# Optional but recommended: split runner/admin auth from poll/report auth
# RUNNER_AUTH_TOKEN=
# Production remote workers must use HTTPS control-plane URLs. Leave this disabled.
# JUDGE_ALLOW_INSECURE_HTTP=0
# Worker hostname reported during registration (default: system hostname)
# JUDGE_WORKER_HOSTNAME=worker-1
# Optional OCI runtime for judge containers (e.g. "runsc" for gVisor); unset = Docker daemon default (runc).
# JUDGE_OCI_RUNTIME=
# Legacy: JUDGE_POLL_URL is still supported for backward compatibility.
# JUDGE_POLL_URL=http://localhost:3000/api/v1/judge/poll
# Comma-separated judge-* image names to prewarm at startup (docker run --rm); empty string disables.
# WORKER_PREWARM_IMAGES=judge-cpp,judge-python,judge-jvm,judge-node,judge-rust,judge-go
# Warm container pool (worker): operator kill switch. When true the worker
# ignores warm-pool targets from the app and judges every test case with a
# cold `docker run`. Default false.
# WORKER_WARM_POOL_DISABLE=false
# Set to 1/true to allow the worker to poll without successful registration (dev/isolated environments only; default: false).
# JUDGE_ALLOW_UNREGISTERED_MODE=0

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BLOCK_MS=900000
SUBMISSION_RATE_LIMIT_MAX_PER_MINUTE=10
SUBMISSION_MAX_PENDING=5
SUBMISSION_GLOBAL_QUEUE_LIMIT=200

# --- Security-relevant knobs (unset = the documented default) ---
# Required in production: the worker enforces trusted-registry + no-dev-tag
# validation. Leave set to 1.
JUDGE_PRODUCTION_MODE=1
# Number of trusted reverse proxies in front of the app. Behind the production
# nginx edge set this to 1 (so X-Forwarded-For is trusted for one hop); 0 means
# X-Forwarded-For is ignored entirely and X-Real-IP is the fallback.
TRUSTED_PROXY_HOPS=1
# Defence-in-depth network isolation around the judge IPC surface. Comma-separated
# IPs/CIDRs allowed to hit /api/v1/judge/*. In production, judge routes fail
# closed when this is unset unless JUDGE_ALLOW_ANY_JUDGE_IP=1 is set.
# JUDGE_ALLOWED_IPS=
# Break-glass override: set to 1 to preserve the legacy allow-all behaviour when
# JUDGE_ALLOWED_IPS is unset. Only use this if network isolation is handled
# elsewhere; otherwise configure JUDGE_ALLOWED_IPS to the worker IP/CIDR.
# JUDGE_ALLOW_ANY_JUDGE_IP=0
# When =1, accounts with an unverified email may run code in the sandbox. Leave
# unset (default deny) unless you intentionally allow unverified email.
# SANDBOX_ALLOW_UNVERIFIED_EMAIL=
# Break-glass override for the pre-restore snapshot gate. Leave unset so a restore
# aborts when the snapshot cannot be written; set =1 only to accept the risk of
# an unrestorable restore.
# ALLOW_UNSNAPSHOTTED_RESTORE=

# --- Backup off-host sync ---
# Optional rclone remote destination (e.g. s3:my-bucket/backups). When set and
# rclone is installed, scripts/backup-db.sh copies the final backup file there.
# Leave unset to keep backups on the local host only.
# BACKUP_REMOTE=

# Optional age public key for encrypting daily backups. Leave unset for
# unencrypted backups (not recommended for production).
# AGE_RECIPIENT=

# --- Worker runtime tuning (all optional; unset = the documented default) ---
# Path to the JSON seccomp profile mounted into worker containers.
# JUDGE_SECCOMP_PROFILE=/etc/judge/seccomp-profile.json
# Directory where failed result payloads are written for manual recovery.
# DEAD_LETTER_DIR=/app/dead-letter
# Runner HTTP server bind address and port inside the worker container.
# RUNNER_HOST=0.0.0.0
# RUNNER_PORT=3001
# Disable the runner HTTP server entirely (rare; default: enabled).
# RUNNER_ENABLED=1
# Max concurrent runner executions (default: max(num_cpus - 1, 1)).
# RUNNER_CONCURRENCY=4
# Per-stream stdout/stderr cap in bytes (default: 128 MiB).
# JUDGE_MAX_OUTPUT_BYTES=134217728
# Compile-phase wall-clock timeout in milliseconds (default: 10 min).
# JUDGE_COMPILE_TIMEOUT_MS=600000
# Compile-phase memory ceiling in MB (default: 2048).
# JUDGE_COMPILE_MEMORY_MB=2048
# Maximum total duration of an in-progress judging claim, in milliseconds
# (default: 600000). In-progress reports that would extend a claim beyond this
# cap are rejected.
# JUDGE_MAX_CLAIM_DURATION_MS=600000
# Absolute upper bound on a single judged run, in milliseconds.
# MAX_TIME_LIMIT_MS=60000

# --- App runtime knobs (all optional; unset = the documented default) ---
# Application log level (trace/debug/info/warn/error).
# LOG_LEVEL=info
# Override the reported app version (default: npm package version).
# APP_VERSION=
# Number of Node.js worker processes; empty = auto-detect.
# WEB_CONCURRENCY=
# Auth/session cache TTL in milliseconds.
# AUTH_CACHE_TTL_MS=
# Set to 1 to skip the custom-seccomp profile requirement in local development.
# DISABLE_COMPILER_LOCAL_FALLBACK=
# Set to 1 to allow the local compiler fallback in restricted modes.
# ENABLE_COMPILER_LOCAL_FALLBACK=
# Set to 1 to enable the cron-driven cleanup tasks at startup.
# ENABLE_CRON_CLEANUP=
# Absolute path to the local data directory (used for uploads, etc.).
# DATA_DIR=
# Legal-hold flag for data-retention maintenance: when set, pruning is skipped.
# DATA_RETENTION_LEGAL_HOLD=
# Warm container pool (app): enables the warm pool by DEFAULT until an admin
# saves an explicit value on the admin settings page
# (/dashboard/admin/settings). Read at runtime by the Next.js app
# (src/lib/judge/warm-pool.ts defaultWarmPoolConfig()). For the oj/auraedu
# deployment, deploy-docker.sh backfills WARM_POOL_DEFAULT_ENABLED=true into
# the remote .env.production automatically (DEPLOY_TARGET=oj/auraedu) — see
# docs/judge-workers.md "Warm container pool". Set true here manually only if
# this deployment should also default the pool on; leave unset otherwise.
# WARM_POOL_DEFAULT_ENABLED=false

# --- Backup / cleanup scripts ---
# Days to retain pre-deploy and daily backups (default: 30).
# BACKUP_RETAIN_DAYS=30
# Disk-usage percentage threshold that triggers safe Docker cleanup.
# DOCKER_CLEANUP_DISK_THRESHOLD=80
# Hours to retain stopped containers/images during safe cleanup.
# DOCKER_CLEANUP_RETAIN=24

# --- AI / email provider credentials (only the provider you use) ---
# Anthropic API credentials for AI-assisted features.
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# AWS SES credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# Resend / SendGrid / SES sender credentials.
# RESEND_API_KEY=
# RESEND_FROM=
# SENDGRID_API_KEY=
# SENDGRID_FROM=
# SES_FROM=
