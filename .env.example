# =============================================================================
# JudgeKit Environment Variables
# Copy to .env and fill in required values.
# =============================================================================

# --- App Runtime ---

# Auth
AUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
# Set to true only behind a trusted reverse proxy or for isolated local automation.
AUTH_TRUST_HOST=false
# Optional: enable hCaptcha for public sign-up from the admin settings page.
# Leave blank to disable hCaptcha integration.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=
# Required for plugin secret storage and API key encryption
PLUGIN_CONFIG_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32
# Required in production (startup gate refuses to boot without it):
# AES-256-GCM key for secrets stored in the DB (SMTP password, hCaptcha
# secret, API keys). A DIFFERENT key from PLUGIN_CONFIG_ENCRYPTION_KEY —
# generate each independently with: openssl rand -hex 32
NODE_ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Email / SMTP (optional)
# SMTP is normally configured from the admin system-settings page (stored
# encrypted in the DB). These env vars are an optional override; if SMTP_HOST,
# SMTP_PORT, SMTP_USER and SMTP_PASS are all set, they take precedence over the
# DB settings.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false           # "true" = implicit TLS (port 465); otherwise STARTTLS
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# DANGER: set to exactly "true" to disable TLS certificate verification (dev/
# self-signed only). Any other value — including empty or "false" — keeps
# verification ON.
# SMTP_SKIP_TLS_VERIFY=

# Privacy / legal
# Data-controller contact shown on the public /privacy page for GDPR/PIPA
# requests. Set this per deployment so candidate requests reach the right
# inbox. Defaults to privacy@xylolabs.com if unset.
# PRIVACY_CONTACT_EMAIL=

# Database
# Current runtime: PostgreSQL
DB_DIALECT=postgresql
# PostgreSQL connection string
DATABASE_URL=postgres://judgekit:judgekit@localhost:5432/judgekit
# Optional host-run override for npm scripts such as db:push, seed,
# languages:sync, and test:e2e when DATABASE_URL uses Docker service DNS
# like postgres://...@db:5432/... inside containers.
# HOST_DATABASE_URL=postgres://judgekit:judgekit@127.0.0.1:5432/judgekit

# Connection pool tuning (all optional; shown with their defaults).
# DATABASE_POOL_MAX must stay comfortably below the server's max_connections
# (and the sum across all app replicas must too) to avoid exhausting Postgres.
# When the pool saturates, requests queue and then fail at the connection
# timeout; the app logs a throttled "[db-pool] connection pool saturated"
# warning so this is visible before it becomes user-facing latency.
# DATABASE_POOL_MAX=20
# DATABASE_POOL_IDLE_TIMEOUT_MS=30000
# DATABASE_POOL_CONNECTION_TIMEOUT_MS=10000
# Recycle a connection after this many seconds of life (0 = disabled). Helps
# shed connections pinned to a backend that survived a failover / pgbouncer
# restart. Leave disabled unless you observe stale-connection symptoms.
# DATABASE_POOL_MAX_LIFETIME_SECONDS=0
# Label shown in pg_stat_activity.application_name for connection-source triage.
# DATABASE_POOL_APP_NAME=judgekit-app

# Optional: when set to 1, deploy-docker.sh passes --force to drizzle-kit push,
# auto-applying destructive schema changes (e.g., DROP COLUMN). Only use after
# reviewing the diff in the deploy log. The Step 5b psql backfill in
# deploy-docker.sh runs regardless of this flag — see AGENTS.md "Database
# migration recovery (DRIZZLE_PUSH_FORCE)" section.
# DRIZZLE_PUSH_FORCE=0

# Rate Limiting
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BLOCK_MS=900000
SUBMISSION_RATE_LIMIT_MAX_PER_MINUTE=5
SUBMISSION_MAX_PENDING=3
SUBMISSION_GLOBAL_QUEUE_LIMIT=100

# Compiler sandbox workspace (Docker-in-Docker only)
# Set to a host-mounted path so sibling containers can access workspace files.
# Not needed for local development (defaults to os.tmpdir()).
# COMPILER_WORKSPACE_DIR=/compiler-workspaces

# Realtime/SSE coordination
# Supported modes:
#   - process-local mode: declare APP_INSTANCE_COUNT=1 (or REALTIME_SINGLE_INSTANCE_ACK=1)
#   - shared PostgreSQL mode: set REALTIME_COORDINATION_BACKEND=postgresql
APP_INSTANCE_COUNT=1
# REALTIME_SINGLE_INSTANCE_ACK=1
# REALTIME_COORDINATION_BACKEND=postgresql

# Code Similarity (Rust sidecar)
CODE_SIMILARITY_URL=http://127.0.0.1:3002
# In Docker deployments set this to the sidecar service, e.g.
# CODE_SIMILARITY_URL=http://code-similarity:3002
# Bearer token required by the sidecar (must match CODE_SIMILARITY_AUTH_TOKEN
# in the sidecar environment). Leave unset for local single-machine dev.
# CODE_SIMILARITY_AUTH_TOKEN=generate-with-openssl-rand-hex-32

# Rate Limiter (Rust sidecar, optional)
# RATE_LIMITER_URL=http://127.0.0.1:3001
# Bearer token required by the sidecar (must match RATE_LIMITER_AUTH_TOKEN
# in the sidecar environment). Leave unset for local single-machine dev.
# RATE_LIMITER_AUTH_TOKEN=generate-with-openssl-rand-hex-32

# Judge Worker
# Preferred: set JUDGE_BASE_URL (claim and report URLs are derived automatically)
JUDGE_BASE_URL=http://localhost:3000/api/v1
# Legacy: JUDGE_POLL_URL is still supported for backward compatibility
# JUDGE_POLL_URL=http://localhost:3000/api/v1/judge/poll
JUDGE_AUTH_TOKEN=generate-with-openssl-rand-hex-32
# Optional but recommended: separate runner/admin bearer token
# RUNNER_AUTH_TOKEN=generate-with-openssl-rand-hex-32
# Only for controlled development networks; non-local worker control-plane URLs must use HTTPS.
# JUDGE_ALLOW_INSECURE_HTTP=0
POLL_INTERVAL=500
JUDGE_DISABLE_CUSTOM_SECCOMP=0
JUDGE_ALLOW_DEFAULT_COMPILE_SECCOMP=0
# Max concurrent submissions to judge in parallel (1-16, default: 1)
JUDGE_CONCURRENCY=1
# Hostname reported to the app server during worker registration (default: system hostname)
# JUDGE_WORKER_HOSTNAME=worker-1
# Optional OCI runtime for judge containers (e.g. "runsc" for gVisor); unset = Docker daemon default (runc).
# JUDGE_OCI_RUNTIME=
# Comma-separated judge-* image names to prewarm at startup (docker run --rm); empty string disables. Default: cpp, python, jvm, node, rust, go.
# WORKER_PREWARM_IMAGES=judge-cpp,judge-python,judge-jvm,judge-node,judge-rust,judge-go
# Set to 1/true to allow the worker to poll without successful registration (dev/isolated environments only; default: false).
# JUDGE_ALLOW_UNREGISTERED_MODE=0

# --- Deployment Targets ---

# Target 1: TEST / STAGING
TEST_HOST=
TEST_DOMAIN=
TEST_ARCH=amd64
TEST_SSH_USER=
TEST_SSH_PASSWORD=
TEST_REMOTE_DIR=
TEST_APP_PORT=3100
TEST_WEB_ADMIN_USER=admin
TEST_WEB_ADMIN_PASSWORD=

# Target 2: PRODUCTION
PROD_DOMAIN=
PROD_ARCH=arm64
PROD_SSH_USER=
PROD_SSH_KEY=
PROD_REMOTE_DIR=
PROD_APP_PORT=3100
PROD_WEB_ADMIN_USER=admin
PROD_WEB_ADMIN_PASSWORD=

# E2E Test (against test server)
E2E_TEST_BASE_URL=
E2E_TEST_USERNAME=
E2E_TEST_PASSWORD=

# E2E Test (against production)
E2E_PROD_BASE_URL=
E2E_PROD_USERNAME=
E2E_PROD_PASSWORD=

# --- Security-relevant knobs (unset = the documented default) ---
# Number of trusted reverse proxies in front of the app. 0 = no trusted
# proxies (X-Forwarded-For is ignored entirely; X-Real-IP is the fallback).
TRUSTED_PROXY_HOPS=1
# Comma-separated IPs/CIDRs allowed to hit /api/v1/judge/* routes. Unset = allow
# all (back-compat). Set this, or set JUDGE_STRICT_IP_ALLOWLIST=1, to enforce
# network isolation around the judge IPC surface.
JUDGE_ALLOWED_IPS=
# When =1, judge routes fail-closed if JUDGE_ALLOWED_IPS is unset (explicit opt-in
# to strict enforcement; do NOT set without also configuring JUDGE_ALLOWED_IPS).
JUDGE_STRICT_IP_ALLOWLIST=
# When =1, accounts with an unverified email may run code in the sandbox.
# Leave unset (default deny) unless you intentionally allow unverified email.
SANDBOX_ALLOW_UNVERIFIED_EMAIL=
# Break-glass override for the pre-restore snapshot gate. Leave unset so a
# restore aborts when the snapshot cannot be written; set =1 only to accept the
# risk of an unrestorable restore.
ALLOW_UNSNAPSHOTTED_RESTORE=
# Comma-separated list of trusted Docker registries for judge/worker images.
# Production startup rejects images outside this list.
TRUSTED_DOCKER_REGISTRIES=
# When =1, the worker enforces production-only validation (trusted registries,
# no dev image tags). Required in production deployments.
JUDGE_PRODUCTION_MODE=

# --- Worker runtime tuning (all optional; unset = the documented default) ---
# Path to the JSON seccomp profile mounted into worker containers.
# JUDGE_SECCOMP_PROFILE=/etc/judge/seccomp-profile.json
# Directory where failed result payloads are written for manual recovery.
# DEAD_LETTER_DIR=/app/dead-letter
# Runner HTTP server bind address and port inside the worker container.
# RUNNER_HOST=0.0.0.0
# RUNNER_PORT=3001
# Disable the runner HTTP server entirely (rare; default: enabled).
# RUNNER_ENABLED=1
# Max concurrent runner executions (default: max(num_cpus - 1, 1)).
# RUNNER_CONCURRENCY=4
# Per-stream stdout/stderr cap in bytes (default: 128 MiB).
# JUDGE_MAX_OUTPUT_BYTES=134217728
# Compile-phase wall-clock timeout in milliseconds (default: 10 min).
# JUDGE_COMPILE_TIMEOUT_MS=600000
# Compile-phase memory ceiling in MB (default: 2048).
# JUDGE_COMPILE_MEMORY_MB=2048
# Absolute upper bound on a single judged run, in milliseconds.
# MAX_TIME_LIMIT_MS=60000

# --- App runtime knobs (all optional; unset = the documented default) ---
# Application log level (trace/debug/info/warn/error).
# LOG_LEVEL=info
# Override the reported app version (default: npm package version).
# APP_VERSION=
# Number of Node.js worker processes; empty = auto-detect.
# WEB_CONCURRENCY=
# Auth/session cache TTL in milliseconds.
# AUTH_CACHE_TTL_MS=
# Set to 1 to skip the custom-seccomp profile requirement in local development.
# DISABLE_COMPILER_LOCAL_FALLBACK=
# Set to 1 to allow the local compiler fallback in restricted modes.
# ENABLE_COMPILER_LOCAL_FALLBACK=
# Set to 1 to enable the cron-driven cleanup tasks at startup.
# ENABLE_CRON_CLEANUP=
# Absolute path to the local data directory (used for uploads, SQLite data, etc.).
# DATA_DIR=
# Legal-hold flag for data-retention maintenance: when set, pruning is skipped.
# DATA_RETENTION_LEGAL_HOLD=

# --- Backup / cleanup scripts ---
# Optional rclone remote for off-host backup copies.
# BACKUP_REMOTE=
# age public key for encrypting daily backups.
# AGE_RECIPIENT=
# Days to retain pre-deploy and daily backups (default: 30).
# BACKUP_RETAIN_DAYS=30
# Disk-usage percentage threshold that triggers safe Docker cleanup.
# DOCKER_CLEANUP_DISK_THRESHOLD=80
# Hours to retain stopped containers/images during safe cleanup.
# DOCKER_CLEANUP_RETAIN=24

# --- AI / email provider credentials (only the provider you use) ---
# Anthropic API credentials for AI-assisted features.
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_DEFAULT_OPUS_MODEL=
# AWS SES credentials.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# Resend / SendGrid / SES sender credentials.
# RESEND_API_KEY=
# RESEND_FROM=
# SENDGRID_API_KEY=
# SENDGRID_FROM=
# SES_FROM=
